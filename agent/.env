OPENAI_API_KEY=""
DASHSCOPE_API_KEY=""
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
ZHIPUAI_API_KEY=""
QDRANT_HOST=""
# 无沙箱时允许执行（不建议）
ALLOW_UNSAFE_CODEACT=true
# EXECUTOR_TOOL_LIMITS：单工具并发上限（JSON）
# EXECUTOR_TOOL_PRIORITIES：单工具调度优先级（JSON）
# EXECUTOR_TASK_TIMEOUT_SECONDS：单任务超时秒数
# CODEACT_TIMEOUT_SECONDS：CodeAct 子进程超时
# CODEACT_MAX_MEMORY_MB：CodeAct 子进程内存限制（Unix）
# CODEACT_MAX_CPU_SECONDS：CodeAct 子进程 CPU 秒数限制（Unix）

# open sandbox settings
OPENSANDBOX_DOMAIN=""
OPENSANDBOX_DEBUG=true
OPENSANDBOX_IMAGE=""
OPENSANDBOX_ENABLED=true
CODEACT_SANDBOX_PROVIDER="opensandbox"

TAVILY_API_KEY=""
