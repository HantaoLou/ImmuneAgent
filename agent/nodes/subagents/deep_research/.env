OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false
# DeepSeek API Configuration
DEEPSEEK_API_KEY=

# DeepSeek Model Configuration (替换所有模型为DeepSeek)
SUMMARIZATION_MODEL=deepseek:deepseek-chat
RESEARCH_MODEL=deepseek:deepseek-chat
COMPRESSION_MODEL=deepseek:deepseek-chat
FINAL_REPORT_MODEL=deepseek:deepseek-reasoner

# Search API Configuration
SEARCH_API=tavily
TAVILY_API_KEY=

# Optional: LangSmith for tracking
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep_research_deepseek
LANGSMITH_TRACING=true

# DeepSeek specific settings
MAX_RESEARCHER_ITERATIONS=4
MAX_CONCURRENT_RESEARCH_UNITS=3
MAX_REACT_TOOL_CALLS=8

# Vector Database Configuration (Qdrant)
# Enable vector database search by configuring these settings
QDRANT_HOST=
QDRANT_PORT=
QDRANT_GRPC_PORT=
QDRANT_API_KEY=
# Multi-collection support: comma-separated list of collection names
# Collections can have different embedding dimensions (1536 or 768)
QDRANT_COLLECTIONS=Immunology,ImmuneAgent,virology,hle_immunology,hle_microbiology,hle_biophysics,hle_genomics,hle_knowledge_graph
QDRANT_PREFER_GRPC=false
QDRANT_HTTPS=false
QDRANT_TIMEOUT=300

# Embedding Model Configuration (1536-dimension, OpenAI)
# Provider: OpenAI-compatible API
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://xiaoai.plus/v1
EMBEDDING_API_KEY=

# Embedding Model Configuration (768-dimension, PubMedBERT) - for 768-dim collections
# Used for virology, hle_immunology, immunology_hle_v2 collections
# HuggingFace model will be downloaded automatically on first use
EMBEDDING_MODEL_768=pritamdeka/S-PubMedBert-MS-MARCO
# HuggingFace mirror for China network (default: https://hf-mirror.com)
HF_ENDPOINT=https://hf-mirror.com

# Vector Search Tool Model Configuration
VECTOR_SCORING_MODEL=deepseek:deepseek-chat
VECTOR_SUMMARIZATION_MODEL=deepseek:deepseek-chat
