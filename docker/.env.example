# Data root directory for persistent volumes
DATA_ROOT=/data_new/antibody_gen/data

# Qdrant Configuration
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# PostgreSQL Configuration
POSTGRES_PORT=5432
POSTGRES_DB=antibody_gen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-it

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=change-it
